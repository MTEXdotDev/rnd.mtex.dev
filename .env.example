# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="PHP-Zero"
APP_ENV=development        # development | production
APP_DEBUG=true             # true = detailed error pages; false = generic 500
APP_TIMEZONE=Europe/Berlin

# APP_ASSET_URL=https://cdn.example.com

# ── Database ──────────────────────────────────────────────────────────────────
# Set DB_DRIVER to either 'mysql' or 'sqlite'.

DB_DRIVER=sqlite

DB_PATH=

# MySQL / MariaDB (only used when DB_DRIVER=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=php_zero
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_NAME=phpzero_session
SESSION_LIFETIME=7200      # seconds (2 hours)
SESSION_SECURE=false       # set to true in production (requires HTTPS)
SESSION_SAMESITE=Lax       # None | Lax | Strict

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=app            # default channel name  (file: storage/logs/{channel}-YYYY-MM-DD.log)
LOG_LEVEL=debug            # debug | info | notice | warning | error | critical | alert | emergency
# LOG_PATH=                # override log directory (absolute path)

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=0                # default TTL in seconds; 0 = never expires
# CACHE_PATH=              # override cache directory (absolute path)
